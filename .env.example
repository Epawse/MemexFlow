# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Supabase service_role (server-only — DO NOT commit, DO NOT expose to client)
# Used by scripts/ for schema inspection + E2E tests that bypass RLS.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# PowerSync Configuration
# Get this from PowerSync dashboard after setting up sync rules
VITE_POWERSYNC_URL=https://your-instance.powersync.com

# Optional: For local development
# VITE_SUPABASE_URL=http://localhost:54321
